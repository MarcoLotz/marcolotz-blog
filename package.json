    "@types/react-dom": "^19.1.0",
    "@types/sanitize-html": "^2.16.0",
    "eslint": "^9.30.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.0",
    "postcss": "^8.5.0",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
